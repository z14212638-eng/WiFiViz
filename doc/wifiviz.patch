     LIBRARIES_TO_LINK ${libwifiviz}
 )
+
+# Full-GUI launcher, registered as a module example so it can be started with
+#   ./ns3 run wifiviz-visualizer
+# No need to copy tools/visualizer.cc into scratch/: ns-3 resolves `./ns3 run`
+# targets across src/ and contrib/ modules, not just scratch/.

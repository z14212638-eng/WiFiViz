diff --git a/model/SniffUtils.cc b/model/SniffUtils.cc
index bc1b769..046303b 100644
--- a/model/SniffUtils.cc
+++ b/model/SniffUtils.cc
@@ -348,10 +348,29 @@ SniffUtils::Initialize(const NetDeviceContainer& devices, double simulationTime)
 {
     this->Set_simulation_time(simulationTime);
 
-    m_shm = new boost::interprocess::managed_shared_memory(boost::interprocess::open_or_create,
-                                                           SHM_NAME,
-                                                           1024UL * 1024 * 1024); // 1GB
-    m_ring = m_shm->find_or_construct<RingBuffer>("PpduRing")();
+    // The segment holds exactly one fixed-size RingBuffer. Size it to that
+    // object plus a small slack for the Boost segment-manager bookkeeping,
+    // rather than an arbitrary 1 GiB. Capacity is governed by MAX_PPDU_NUM,
+    // not by the segment size, so over-provisioning buys nothing and only
+    // risks the OS refusing the allocation (small /dev/shm, containers, macOS).
+    const std::size_t segmentSize = sizeof(RingBuffer) + 64UL * 1024;
+    try
+    {
+        m_shm = new boost::interprocess::managed_shared_memory(
+            boost::interprocess::open_or_create, SHM_NAME, segmentSize);
+        m_ring = m_shm->find_or_construct<RingBuffer>("PpduRing")();
+    }
+    catch (const boost::interprocess::interprocess_exception& e)
+    {
+        std::cerr << "[WiFiViz] Could not create the " << (segmentSize >> 20)
+                  << " MiB shared-memory segment '" << SHM_NAME << "': " << e.what()
+                  << "\n[WiFiViz] Visualization is disabled for this run; the simulation"
+                  << " will continue normally." << std::endl;
+        delete m_shm;
+        m_shm = nullptr;
+        m_ring = nullptr;
+        return false;
+    }
     m_ring->write_index = 0;
     m_ring->read_index = 0;
     g_throughputWindow.clear();
@@ -1061,7 +1080,7 @@ void
 ShmExample()
 {
     managed_shared_memory shm(open_or_create, SHM_NAME,
-                              1024UL * 1024 * 1024); // 1GB
+                              sizeof(RingBuffer) + 64UL * 1024);
 
     RingBuffer* ring = shm.find_or_construct<RingBuffer>("PpduRing")();
     ring->write_index = 0;

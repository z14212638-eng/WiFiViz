diff --git a/CMakeLists.txt b/CMakeLists.txt
index 87db254..f629a3a 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -3,6 +3,28 @@ if(HAVE_STDINT_H)
     add_definitions(-DHAVE_STDINT_H)
 endif()
 
+# ---------------------------------------------------------------------------
+# Prerequisite detection.
+#
+# The wifiviz ns-3 library requires nlohmann/json (model/QNs3.cc) and
+# Boost.Interprocess (model/SniffUtils.*). These are NOT bundled with ns-3.
+# If either is missing, skip the whole module so it is reported under
+# "Modules that cannot be built" rather than failing the build at compile
+# time with a confusing "file not found" error.
+# ---------------------------------------------------------------------------
+find_package(nlohmann_json 3.2.0 QUIET)
+check_include_file_cxx("boost/interprocess/managed_shared_memory.hpp"
+                       WIFIVIZ_HAVE_BOOST_IPC)
+
+if(NOT nlohmann_json_FOUND)
+    message(STATUS "Skipping contrib module 'wifiviz': nlohmann_json (>= 3.2.0) not found")
+    return()
+endif()
+if(NOT WIFIVIZ_HAVE_BOOST_IPC)
+    message(STATUS "Skipping contrib module 'wifiviz': Boost.Interprocess headers not found")
+    return()
+endif()
+
 set(examples_as_tests_sources)
 if(${ENABLE_EXAMPLES})
     set(examples_as_tests_sources
@@ -10,9 +32,9 @@ if(${ENABLE_EXAMPLES})
         )
 endif()
 
-set(CMAKE_CXX_STANDARD 23)
-set(CMAKE_CXX_STANDARD_REQUIRED ON)
-set(CMAKE_CXX_EXTENSIONS OFF) 
+# The library targets only C++17/20 features. Inherit the ns-3 default
+# (C++20) instead of forcing C++23, which needlessly fails on older or
+# AppleClang toolchains. Do not force CMAKE_CXX_STANDARD here.
 
 build_lib(
     LIBNAME wifiviz
@@ -28,9 +50,28 @@ build_lib(
                       ${libmobility}
                       ${libaodv}
                       ${libwifi}
+                      nlohmann_json::nlohmann_json
     TEST_SOURCES test/wifiviz-test-suite.cc
                  ${examples_as_tests_sources}
 )
 
-# Include the Qt UI frontend application
-add_subdirectory(ui)
+# Boost.Interprocess is header-only; make sure its include path reaches the
+# module library (the headers were located by check_include_file_cxx above,
+# but build_lib does not add Boost automatically).
+find_package(Boost QUIET)
+if(Boost_INCLUDE_DIRS)
+    target_include_directories(${libwifiviz} PRIVATE ${Boost_INCLUDE_DIRS})
+endif()
+
+# Qt GUI front-end (WiFiVizApp) is OPTIONAL. Only descend into ui/ when Qt is
+# available, otherwise a missing Qt would make `./ns3 configure` fail for the
+# ENTIRE tree rather than just skipping this front-end.
+find_package(Qt6 COMPONENTS Core Gui Widgets QUIET)
+if(NOT Qt6_FOUND)
+    find_package(Qt5 5.15 COMPONENTS Core Gui Widgets QUIET)
+endif()
+if(Qt6_FOUND OR Qt5_FOUND)
+    add_subdirectory(ui)
+else()
+    message(STATUS "wifiviz: Qt (6 or 5.15+) not found; skipping the WiFiVizApp GUI front-end")
+endif()
